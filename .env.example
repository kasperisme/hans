# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Ollama
LOCAL_MODEL=qwen3.5:9b
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_THINK=false                  # true/false or low/medium/high
# OLLAMA_KEEP_ALIVE=30m               # keep model in VRAM between asks (-1 = indefinite)
# OLLAMA_CONNECT_TIMEOUT_S=60
# OLLAMA_READ_TIMEOUT_S=              # empty = no limit (recommended)

# SwingTrader
# SWINGTRADER_ROOT=/Users/kasperisme/projects/swingtrader
# SWINGTRADER_PYTHON=python3
# SWINGTRADER_TIMEOUT_SEC=3600
# HANS_DUCKDB_PATH=                   # optional override for DuckDB path

# System prompt append
# HANS_SYSTEM_APPEND=

# Todoist
TODOIST_API_TOKEN=your_todoist_api_token
